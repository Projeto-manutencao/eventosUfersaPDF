# Django
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS (Frontend local)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# E-mail de solicitacoes de manutencao
# Em desenvolvimento, o backend imprime o e-mail no terminal por padrao.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
MANUTENCAO_EMAIL_EQUIPE=suporte.eventosufersa@gmail.com

# SMTP Gmail (use senha de app, nao a senha normal da conta)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=suporte.eventosufersa@gmail.com
# EMAIL_HOST_PASSWORD=sua-senha-de-app
# DEFAULT_FROM_EMAIL=suporte.eventosufersa@gmail.com

# Production (Amplify/RDS) - configure no painel da AWS
# DJANGO_SECRET_KEY=...
# DEBUG=False
# ALLOWED_HOSTS=seu-app.amplifyapp.com
# CORS_ALLOWED_ORIGINS=https://seu-frontend.com
# CSRF_TRUSTED_ORIGINS=https://seu-frontend.com
# DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=require
